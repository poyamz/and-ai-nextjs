# =============================================================================
# Supabase Configuration
# =============================================================================
# Get these values from your Supabase project:
#   - Hosted: https://supabase.com/dashboard/project/_/settings/api
#   - Local:  printed when you run `npx supabase start`

# Public Supabase URL — safe to expose to the browser
# Local dev:
#   - On host machine directly:     http://127.0.0.1:54321
#   - Inside devcontainer:          http://host.docker.internal:54321
# Hosted: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key — safe to expose to the browser.
# Format: sb_publishable_xxxxxxxxxxxx
# This key respects Row Level Security policies, so it cannot read or write
# data unless an RLS policy explicitly allows it.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# =============================================================================
# Server-only secrets — NEVER expose these to the browser
# =============================================================================
# Do not prefix these with NEXT_PUBLIC_. Next.js inlines NEXT_PUBLIC_* vars
# into client bundles, which would leak them to anyone who views your site.

# Secret key — bypasses Row Level Security entirely.
# Format: sb_secret_xxxxxxxxxxxx
# Use only in server-side code (Route Handlers, Server Actions, scripts).
# Treat like a database password. Rotate immediately if exposed.
SUPABASE_SECRET_KEY=

# =============================================================================
# Site URL — used for auth redirects (email confirmations, OAuth callbacks)
# =============================================================================
# Local development: http://localhost:3000
# Production: your real domain, e.g. https://yourapp.com
NEXT_PUBLIC_SITE_URL=